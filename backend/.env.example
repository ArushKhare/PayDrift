# Local dev: copy to .env and fill in.
# On Render: set these as env vars on the paydrift-backend service instead
# (render.yaml already declares the keys it expects).

ANTHROPIC_API_KEY=

# Local dev only — points at the service account JSON file on disk.
# On Render there is no such file, so set FIREBASE_CREDENTIALS_JSON instead:
# paste the *entire contents* of firebase-service-account.json as one line.
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=

# Any random long string. auth.py falls back to an insecure hackathon
# default if this is unset — always set it explicitly on Render.
JWT_SECRET=

PORT=8000
HOST=0.0.0.0
